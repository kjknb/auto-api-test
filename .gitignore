# ============================================================
# .gitignore
# Git 忽略规则 —— 防止临时文件、报告和敏感配置被提交
# ============================================================

# ---- Python 编译缓存 ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/

# ---- 虚拟环境 ----
venv/
env/
.venv/

# ---- IDE 配置 ----
.idea/
.vscode/
*.swp
*.swo
*~
*.iml

# ---- 系统文件 ----
.DS_Store
Thumbs.db

# ---- 测试报告（运行时生成，不需要入库） ----
reports/allure-results/
reports/allure-report/
reports/logs/
*.log

# ---- 敏感配置（只保留 .example 模板） ----
config/config.yaml
config/config.local.yaml
config/token.yaml

# ---- 测试上下文（运行时生成） ----
extract.yaml

# ---- Pytest 缓存 ----
.pytest_cache/
